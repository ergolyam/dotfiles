{{- $profiles := list "desktop" "server" -}}
{{- $profile := promptChoiceOnce . "profile" "Profile" $profiles -}}
[data]
profile = {{ $profile | quote }}
{{ if eq $profile "desktop" }}
wm = "niri"
terminal = "alacritty"
notifications = "mako"
launcher = "fuzzel"
install_fonts = true
install_cursor = true
{{ end }}
