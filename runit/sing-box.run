#!/bin/sh
name="sing-box"

podman rm -f "${name}" || true

exec podman run --rm --name "${name}" \
    -p 127.0.0.1:2080:2080 \
    -v $HOME/.config/service/sing-box/config.json:/etc/sing-box/config.json:Z \
    --device /dev/net/tun \
    --cap-add NET_ADMIN \
    ghcr.io/sagernet/sing-box:latest \
    -D /var/lib/sing-box -C /etc/sing-box/ run
